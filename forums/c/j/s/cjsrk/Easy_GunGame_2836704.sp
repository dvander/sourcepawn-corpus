/* Plugin Template generated by Pawn Studio */

#include <sdktools>
#include <sourcemod>
#include <sdkhooks>
#include <cstrike>

public Plugin:myinfo = {
    name = "Easy GunGame",
    author = "cjsrk",
    description = "<- Description ->",
    version = "1.0",
    url = "<- URL ->"
}


ArrayList maps;
int serial = -1;

new Handle:cvarEnable;
new Handle:cvarBotsUse;
new Handle:cvarBotWin;
new Handle:cvarEndType;
new Handle:cvarGunOrder;
new Handle:cvarIsPlayTipSound;
new bool:isEnabled;    // 启动或禁用插件变量
new bool:BotsUse;    // Bots启用或禁用军备竞赛变量
new bool:BotWin;    // Bot是否能结束军备竞赛变量
int EndType;    // 军备竞赛结束后的操作变量
new bool:GunOrder;    // 军备竞赛武器顺序变量
new bool:IsPlayTipSound;    // 是否播放提示声音变量

// 玩家当前应该装备的军备竞赛武器数组
static int PlayerWeaponList[65] = {0};
// 玩家杀敌数（对于当前武器）
static int PlayerNumberOfKills[65] = {0};
// 列表中的武器数量
static int WeaponsCount = 0;
// 在军备竞赛出现获胜者后冻结统计
static bool FrozenStatistic = false;

static char WeaponName[128][20];    // 军备竞赛武器类名数组
static int WeaponSlot[128] = {0};    // 军备竞赛武器武器插槽（0为主武器，1为副武器，2为近战武器）
static char WeaponDisplayName[128][128];    //军备竞赛武器武器显示在屏幕上的名字  36改128
static int SpecifiedNumberOfKills[128] = {1};    // 该武器升级需要的杀敌数量，不可为0
static int WeaponAmmo[128] = {0};    //军备竞赛武器备弹量
static char WeaponFatherName[128][20];    //军备竞赛武器的父类类名数组，如果该武器是原版武器而非加枪插件添加的武器，则该项必须为空

// 刀具单独升级
static int PlayerWeaponList2[65] = {0};
static int PlayerNumberOfKills2[65] = {0};
static int WeaponsCount2 = 0;
static char WeaponName2[128][20];
static char WeaponDisplayName2[128][128];
static int SpecifiedNumberOfKills2[128];

public OnPluginStart(){
    //设置配置文件
    CreateConVar("sm_easy_gungame_version", "1.0.0", "Plugin version", FCVAR_SPONLY|FCVAR_REPLICATED|FCVAR_NOTIFY);
    cvarEnable = CreateConVar("sm_easy_gungame_enable", "1", "Enable the plugin? (1: Enable; 0: Disable)", _, true, 0.0, true, 1.0);
    cvarBotsUse = CreateConVar("sm_easy_gungame_bots_use", "0", "Enable GunGame for Bots? (1: Enable; 0: Disable)", _, true, 0.0, true, 1.0);
    cvarBotWin = CreateConVar("sm_easy_gungame_bot_win", "1", "Whether to end the round when a Bot achieves all kill requirement (1: Yes; 0: No. Requires sm_easy_gungame_bots_use 1)", _, true, 0.0, true, 1.0);
    cvarEndType = CreateConVar("sm_easy_gungame_end_type", "0", "Action after GunGame ends (0: Next round; 1: Restart map; 2: Random map)", _, true, 0.0, true, 2.0);
    cvarGunOrder = CreateConVar("sm_easy_gungame_gun_order", "0", "Weapon update path order (0: First to last; 1: Last to first)", _, true, 0.0, true, 1.0);
    cvarIsPlayTipSound = CreateConVar("sm_easy_gungame_play_sound", "1", "Play sound when displaying remaining kill requirement (1: Enable; 0: Disable)", _, true, 0.0, true, 1.0);
    AutoExecConfig(true, "plugin.easy_gungame");
    HookConVarChange(cvarEnable, CvarChange);
    HookConVarChange(cvarBotsUse, CvarChange);
    HookConVarChange(cvarBotWin, CvarChange);
    HookConVarChange(cvarEndType, CvarChange);
    HookConVarChange(cvarGunOrder, CvarChange);
    HookConVarChange(cvarIsPlayTipSound, CvarChange);
    
    HookEvent("round_start", Event_RoundStart);    //注册事件
    HookEvent("player_spawn", SpawnEvent, EventHookMode_Post);    
    HookEvent("player_death", PlayerDeath);
    AddCommandListener(Command_Dorp, "drop");
    
    maps = new ArrayList(512, 0);
}


public OnMapStart()
{
    //读取军备竞赛武器信息文件  
    WeaponsCount = 0;
    WeaponsCount2 = 0;
    new String:filepath[PLATFORM_MAX_PATH];
    BuildPath(Path_SM, filepath, PLATFORM_MAX_PATH, "configs/EasyGunGameList.txt");
    new Handle:file = OpenFile(filepath, "r"); 
    if(file != INVALID_HANDLE){
        
        decl String:fileline[128];
        decl String:data[6][128];
        // int num = 0;     
        
        while(ReadFileLine(file, fileline, 128))
        {       
            if(ExplodeString(fileline, "><", data, 6, 128) == 6)
            {
                if(strlen(data[0]) > 0)
                {
                    //将Bot新武器信息文件的数据载入各个新武器信息数组
                    TrimString(data[0]);
                    TrimString(data[1]);
                    TrimString(data[2]);
                    TrimString(data[3]);
                    TrimString(data[4]);
                    TrimString(data[5]);
                    
                    if(strlen(data[0]) > 0)
                        ReplaceString(data[0], strlen(data[0]), "<", "");
                    if(strlen(data[5]) > 0)
                        ReplaceString(data[5], strlen(data[5]), ">", "");
                    
                    int My_WeaponSlot = 0;
                    if(strlen(data[1]) >= 0)
                        My_WeaponSlot = StringToInt(data[1]);

                    if(My_WeaponSlot == 2)
                    {
                        strcopy(WeaponName2[WeaponsCount2], strlen(data[0]) + 1, data[0]);
                        strcopy(WeaponDisplayName2[WeaponsCount2], strlen(data[2]) + 1, data[2]);

                        int My_SpecifiedNumberOfKills = 1;
                        if(strlen(data[3]) >= 1)
                            My_SpecifiedNumberOfKills = StringToInt(data[3]);
                        if(My_SpecifiedNumberOfKills >= 1 && My_SpecifiedNumberOfKills <= 100)
                            SpecifiedNumberOfKills2[WeaponsCount2] = My_SpecifiedNumberOfKills;
                        else
                            SpecifiedNumberOfKills2[WeaponsCount2] = 1;

                        WeaponsCount2++;
                    }
                    else
                    {
                        if(My_WeaponSlot >= 0 && My_WeaponSlot < 3)
                            WeaponSlot[WeaponsCount] = My_WeaponSlot;
                        else
                            WeaponSlot[WeaponsCount] = 0;

                        strcopy(WeaponName[WeaponsCount], strlen(data[0]) + 1, data[0]);
                        strcopy(WeaponDisplayName[WeaponsCount], strlen(data[2]) + 1, data[2]);
                        strcopy(WeaponFatherName[WeaponsCount], strlen(data[5]) + 1, data[5]);
                        
                        int My_SpecifiedNumberOfKills = 1;
                        if(strlen(data[3]) >= 1)
                            My_SpecifiedNumberOfKills = StringToInt(data[3]);
                        if(My_SpecifiedNumberOfKills >= 1 && My_SpecifiedNumberOfKills <= 100)
                            SpecifiedNumberOfKills[WeaponsCount] = My_SpecifiedNumberOfKills;
                        else
                            SpecifiedNumberOfKills[WeaponsCount] = 1;
                        
                        int My_WeaponAmmo = 0;
                        if(strlen(data[4]) >= 0)
                            My_WeaponAmmo = StringToInt(data[4]);
                        if(My_WeaponAmmo > 0)
                            WeaponAmmo[WeaponsCount] = My_WeaponAmmo;
                        else
                            WeaponAmmo[WeaponsCount] = 0;
                        
                        WeaponsCount++;
                    }
                }                               
            }           
        }
        
        CloseHandle(file);      
    }
    
    PrecacheSound("GunGameSound/KillTipSound.wav", true);
}


//读取配置文件的cvar的值
public OnConfigsExecuted()
{
    isEnabled = GetConVarBool(cvarEnable);
    BotsUse = GetConVarBool(cvarBotsUse);
    BotWin = GetConVarBool(cvarBotWin);
    EndType = GetConVarInt(cvarEndType);
    GunOrder = GetConVarBool(cvarGunOrder);
    IsPlayTipSound = GetConVarBool(cvarIsPlayTipSound);
}


//cvar值变化时的响应数组
public CvarChange(Handle:convar, const String:oldValue[], const String:newValue[])
{
    if(convar == cvarEnable)
    {
        if(StringToInt(newValue) == 1)
        {
            isEnabled = true;
        }
        else
        {
            isEnabled = false;
        }
    }
    if(convar == cvarBotsUse)
    {
        if(StringToInt(newValue) == 1)
        {
            BotsUse = true;
        }
        else
        {
            BotsUse = false;
        }
    }
    if(convar == cvarBotWin)
    {
        if(StringToInt(newValue) == 1)
        {
            BotWin = true;
        }
        else
        {
            BotWin = false;
        }
    }
    if(convar == cvarEndType)
    {
        if(StringToInt(newValue) == 0)
        {
            EndType = 0;
        }
        else if(StringToInt(newValue) == 1)
        {
            EndType = 1;
        }
        else
        {
            EndType = 2;
        }
    }
    if(convar == cvarGunOrder)
    {
        if(StringToInt(newValue) == 1)
        {
            GunOrder = true;
        }
        else
        {
            GunOrder = false;
        }
    }
    if(convar == cvarIsPlayTipSound)
    {
        if(StringToInt(newValue) == 1)
        {
            IsPlayTipSound = true;
        }
        else
        {
            IsPlayTipSound = false;
        }
    }
}


public OnClientPutInServer(client)
{
    SDKHook(client, SDKHook_WeaponCanSwitchTo, Hook_WeaponCanSwitch);
    SDKHook(client, SDKHook_WeaponDrop, OnWeaponDrop);
    SDKHook(client, SDKHook_WeaponEquip, OnWeaponEquip);
}


//检测玩家属性函数（bot获取新武器使用）
bool:IsClient(Client, bool:Alive)
{
    return Client <= MaxClients && IsClientConnected(Client) && IsClientInGame(Client) && (Alive && IsPlayerAlive(Client));
}


// 回合开始
public Event_RoundStart(Handle:event, const String:name[], bool:dontBroadcast)
{
    if(isEnabled == false)
        return;
    if(WeaponsCount < 3)
        return;
    
    char szClass[65];
    
    GameRules_SetProp("m_iRoundTime", 3600, 4, 0, true);    // 解除回合时间限制
    
    FrozenStatistic = false;    // 解除统计冻结
    
    for(new client = 1;client <=MaxClients;client++)
    {
        if(!IsValidEntity(client))
            continue;
        
        decl String:classname[32];
        GetEdictClassname(client, classname, sizeof(classname));
        if(!StrEqual(classname, "player"))
            continue;
        
        // 玩家当前武器数组清空
        if(IsClientConnected(client) && IsClientInGame(client))
        {
            if(GunOrder == false)
                PlayerWeaponList[client] = 0;
            else
                PlayerWeaponList[client] = WeaponsCount - 1;

            SetClientFrags(client, 0);    // 回合开始清空玩家得分
            SetClientDeaths(client, 0);    // 回合开始清空玩家死亡次数记录

            if(GunOrder == false)
                PlayerWeaponList2[client] = 0;
            else
                PlayerWeaponList2[client] = WeaponsCount2 - 1;
        }
        
        PlayerNumberOfKills[client] = 0;    // 玩家当前武器杀敌数清零
        PlayerNumberOfKills2[client] = 0;    // 玩家当前武器杀敌数清零
        
        // if(IsClientConnected(client) && IsClientInGame(client) && !IsFakeClient(client))
        // {
            // PrintToChat(client, "武器数量：%d", WeaponsCount);
            // for(int i = 0; i < WeaponsCount; i++) {
                // PrintToChat(client, "武器名称：%s", WeaponName[i]);
                // PrintToChat(client, "武器插槽：%d", WeaponSlot[i]);
                // PrintToChat(client, "显示名称：%s", WeaponDisplayName[i]);
                // PrintToChat(client, "杀敌要求：%d", SpecifiedNumberOfKills[i]);
                // PrintToChat(client, "父类名称：%s", WeaponFatherName[i]);
                // PrintToChat(client, "备弹量：%d", WeaponAmmo[i]);
            // }
        // }
    }
}


// 玩家生成事件
public Action:SpawnEvent(Handle:event,const String:name[],bool:dontBroadcast)
{
    new client_id = GetEventInt(event, "userid");
    new client = GetClientOfUserId(client_id); 
    
    if(isEnabled == true && WeaponsCount >= 3)
    {
        if(IsClientConnected(client) && IsClientInGame(client))
        {
            // 为玩家配置军备竞赛武器
            if(!IsFakeClient(client))
            {
                CreateTimer(0.1, GivePlayerWeapon, client);
                
                // 为玩家免费装备头盔+防弹衣
                if(IsPlayerAlive(client))
                {
                    if(HasEntProp(client, Prop_Send, "m_ArmorValue") == true)
                    {
                        SetEntProp(client, Prop_Send, "m_ArmorValue", 100);
                        SetEntProp(client, Prop_Send, "m_bHasHelmet", 1);
                    }
                }
            }   
            else
            {
                if(BotsUse == true)
                {
                    CreateTimer(0.2, GivePlayerWeapon, client);
                    CreateTimer(2.5, DetectCurrentWeapon, client);
                    
                    // 为玩家免费装备头盔+防弹衣
                    if(IsPlayerAlive(client))
                    {
                        if(HasEntProp(client, Prop_Send, "m_ArmorValue") == true)
                        {
                            SetEntProp(client, Prop_Send, "m_ArmorValue", 100);
                            SetEntProp(client, Prop_Send, "m_bHasHelmet", 1);
                        }
                    }
                }
            }
        }       
    }       
}


// 检测Bot获取武器是否有错误，如有则重新分配武器（修复盾牌插件等导致的错误）
public Action:DetectCurrentWeapon(Handle timer, int client)
{
    if(IsClient(client, true))
    {
        int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
        
        if(num < WeaponsCount)
        {
            new currentWeapon = GetEntPropEnt(client, Prop_Send, "m_hActiveWeapon");
            if ((currentWeapon > 0) && IsValidEdict(currentWeapon))
            {
                decl String:sWeapon[32];
                GetEdictClassname(currentWeapon, sWeapon, sizeof(sWeapon));
                ReplaceStringEx(sWeapon, strlen(sWeapon), "weapon_", "");
                TrimString(sWeapon);
                
                if(!StrEqual(sWeapon, WeaponName[num]))    // 如果Bot当前装备的武器与应该装备的军备竞赛武器名字不同，则修复错误
                {
                    CreateTimer(0.0, GivePlayerWeapon, client);
                }
            }
            else
            {
                CreateTimer(0.0, GivePlayerWeapon, client);    // 如果Bot当前装备的武器为空，则修复错误
            }
        }
    }
    return Plugin_Continue;
}


// 为玩家配置军备竞赛武器
public Action:GivePlayerWeapon(Handle timer, int client)
{
    if(FrozenStatistic == true)
        return Plugin_Continue;
    
    if(IsClient(client, true))
    {
        int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
        
        if(num < WeaponsCount)
        {
            if(StrEqual("", WeaponFatherName[num]))    // 如果是原版武器
            {
                new ThisSlot = GetPlayerWeaponSlot(client, WeaponSlot[num]);
                if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                    AcceptEntityInput(ThisSlot, "kill");
                if(!StrEqual("", WeaponName[num]))
                {
                    char PreStr0[] = "weapon_";
                    char NewWeaponName[32];
                    Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName[num]);
                    TrimString(NewWeaponName);
                    new weapon = CreateEntityByName(NewWeaponName);
                    DispatchSpawn(weapon);
                    ActivateEntity(weapon);
                    EquipPlayerWeapon(client,weapon);   
                    if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                    {
                        new MyWeaponType = GetEntProp(weapon, Prop_Data, "m_iPrimaryAmmoType");
                        if(GetEntProp(client, Prop_Data, "m_iAmmo", 4, MyWeaponType) <= 0)
                        {
                            SetEntProp(client, Prop_Data, "m_iAmmo", WeaponAmmo[num], 4, MyWeaponType); 
                        }
                    }
                    
                    // 移除其他多余的武器（近战武器和投掷武器除外）
                    if(WeaponSlot[num] == 0)
                    {
                        int SecWeapon = GetPlayerWeaponSlot(client, 1);
                        if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                            AcceptEntityInput(SecWeapon, "kill");
                    }
                    else if(WeaponSlot[num] == 1)
                    {
                        int MainWeapon = GetPlayerWeaponSlot(client, 0);
                        if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                            AcceptEntityInput(MainWeapon, "kill");
                        
                        char WeaponStr[64];
                        Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        TrimString(WeaponStr);
                        FakeClientCommand(client, "use %s", WeaponStr);     
                        if(IsFakeClient(client))
                            SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);                
                    }
                    else
                    {
                        int MainWeapon = GetPlayerWeaponSlot(client, 0);
                        int SecWeapon = GetPlayerWeaponSlot(client, 1);
                        if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                            AcceptEntityInput(MainWeapon, "kill");
                        if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                            AcceptEntityInput(SecWeapon, "kill");
                        
                        char WeaponStr[64];
                        Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        TrimString(WeaponStr);
                        FakeClientCommand(client, "use %s", WeaponStr);
                        if(IsFakeClient(client))
                            SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);
                    }
                    
                    // 显示提示文字
                    if((GunOrder == false && PlayerWeaponList[client] == 0) || (GunOrder == true && ((PlayerWeaponList[client] + 1) == WeaponsCount)))
                    {                   
                        char PreStr[128];
                        if(!StrEqual("", WeaponDisplayName[num]))
                            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "GunGame round started! Weapon obtained: ", WeaponDisplayName[num], ". Kill requirement: ", SpecifiedNumberOfKills[num]);
                        else
                            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "GunGame round started! Weapon obtained: ", WeaponName[num], ". Kill requirement: ", SpecifiedNumberOfKills[num]);
                        TrimString(PreStr);
                        // PrintCenterText(client, PreStr); 
                        PrintHintText(client, PreStr);
                        
                        // 播放提示音
                        if(IsPlayTipSound == true)
                            CreateTimer(1.0, Timer_PlayerTipSound2, client);
                    }
                    else
                    {
                        char PreStr[32];
                        Format(PreStr, sizeof(PreStr), "%s%d", "Kill requirement remaining: ", SpecifiedNumberOfKills[num] - PlayerNumberOfKills[client]);
                        TrimString(PreStr);
                        // PrintCenterText(client, PreStr);
                        PrintHintText(client, PreStr);
                        
                        // 播放提示音
                        if(IsPlayTipSound == true)
                            CreateTimer(0.75, Timer_PlayerTipSound, client);
                    }       
                }
                
            }
            else    // 如果是加枪插件添加的武器
            {
                new ThisSlot = GetPlayerWeaponSlot(client, WeaponSlot[num]);
                if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                    AcceptEntityInput(ThisSlot, "kill");
                if(!StrEqual("", WeaponName[num]))
                {
                    char PreStr0[] = "weapon_";
                    char NewWeaponName[32];
                    Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName[num]);
                    TrimString(NewWeaponName);
                    char NewFatherWeaponName[32];
                    Format(NewFatherWeaponName, sizeof(NewFatherWeaponName), "%s%s", PreStr0, WeaponFatherName[num]);
                    TrimString(NewFatherWeaponName);
                    
                    new weapon = CreateEntityByName(NewFatherWeaponName);
                    DispatchKeyValue(weapon,"classname",NewWeaponName);
                    if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                    {
                        char NewAmmo[10];
                        IntToString(WeaponAmmo[num], NewAmmo, sizeof(NewAmmo));
                        TrimString(NewAmmo);        
                        DispatchKeyValue(weapon,"ammo",NewAmmo);
                    }
                    DispatchSpawn(weapon);
                    ActivateEntity(weapon);
                    EquipPlayerWeapon(client,weapon);   
                    if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                    {
                        new MyWeaponType = GetEntProp(weapon, Prop_Data, "m_iPrimaryAmmoType");
                        if(GetEntProp(client, Prop_Data, "m_iAmmo", 4, MyWeaponType) <= 0)
                        {
                            SetEntProp(client, Prop_Data, "m_iAmmo", WeaponAmmo[num], 4, MyWeaponType); 
                        }
                    }
                    
                    // 移除其他多余的武器（近战武器和投掷武器除外）
                    if(WeaponSlot[num] == 0)
                    {
                        int SecWeapon = GetPlayerWeaponSlot(client, 1);
                        if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                            AcceptEntityInput(SecWeapon, "kill");
                    }
                    else if(WeaponSlot[num] == 1)
                    {
                        int MainWeapon = GetPlayerWeaponSlot(client, 0);
                        if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                            AcceptEntityInput(MainWeapon, "kill");
                        
                        char WeaponStr[64];
                        Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        TrimString(WeaponStr);
                        FakeClientCommand(client, "use %s", WeaponStr);
                        if(IsFakeClient(client))
                            SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);
                    }
                    else
                    {
                        int MainWeapon = GetPlayerWeaponSlot(client, 0);
                        int SecWeapon = GetPlayerWeaponSlot(client, 1);
                        if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                            AcceptEntityInput(MainWeapon, "kill");
                        if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                            AcceptEntityInput(SecWeapon, "kill");
                        
                        char WeaponStr[64];
                        Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        TrimString(WeaponStr);
                        FakeClientCommand(client, "use %s", WeaponStr);
                        if(IsFakeClient(client))
                            SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);
                    }
                    
                    // 显示提示文字
                    if((GunOrder == false && PlayerWeaponList[client] == 0) ||(GunOrder == true && ((PlayerWeaponList[client] + 1) == WeaponsCount)))
                    {
                        char PreStr[128];
                        if(!StrEqual("", WeaponDisplayName[num]))
                            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "GunGame round started! Weapon obtained: ", WeaponDisplayName[num], ". Kill requirement: ", SpecifiedNumberOfKills[num]);
                        else
                            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "GunGame round started! Weapon obtained: ", WeaponName[num], ". Kill requirement: ", SpecifiedNumberOfKills[num]);
                        TrimString(PreStr);
                        // PrintCenterText(client, PreStr); 
                        PrintHintText(client, PreStr);
                        
                        // 播放提示音
                        if(IsPlayTipSound == true)
                            CreateTimer(1.0, Timer_PlayerTipSound2, client);
                    }
                    
                    else
                    {
                        char PreStr[32];
                        Format(PreStr, sizeof(PreStr), "%s%d", "Kill requirement remaining: ", SpecifiedNumberOfKills[num] - PlayerNumberOfKills[client]);
                        TrimString(PreStr);
                        // PrintCenterText(client, PreStr);
                        PrintHintText(client, PreStr);
                        
                        // 播放提示音
                        if(IsPlayTipSound == true)
                            CreateTimer(0.75, Timer_PlayerTipSound, client);
                    }
                }
            }
        }

        num = PlayerWeaponList2[client];

        if(num < WeaponsCount2)
        {
            if(StrEqual("knife", WeaponName2[num]))    // 如果是原版武器
            {
                new ThisSlot = GetPlayerWeaponSlot(client, 2);
                if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                    AcceptEntityInput(ThisSlot, "kill");

                new weapon = CreateEntityByName("weapon_knife");
                
                DispatchSpawn(weapon);
                ActivateEntity(weapon);
                EquipPlayerWeapon(client,weapon);

                char WeaponStr[64];
                Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                TrimString(WeaponStr);
                FakeClientCommand(client, "use %s", WeaponStr);
                if(IsFakeClient(client))
                    SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);         
            }
            else    // 如果是加枪插件添加的武器
            {
                new ThisSlot = GetPlayerWeaponSlot(client, 2);
                if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                    AcceptEntityInput(ThisSlot, "kill");
                if(!StrEqual("", WeaponName2[num]))
                {
                    char PreStr0[] = "weapon_";
                    char NewWeaponName[32];
                    Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName2[num]);
                    TrimString(NewWeaponName);
                    
                    new weapon = CreateEntityByName("weapon_knife");
                    DispatchKeyValue(weapon,"classname",NewWeaponName);
  
                    DispatchSpawn(weapon);
                    ActivateEntity(weapon);
                    EquipPlayerWeapon(client,weapon);

                    char WeaponStr[64];
                    Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                    TrimString(WeaponStr);
                    FakeClientCommand(client, "use %s", WeaponStr);
                    if(IsFakeClient(client))
                        SetEntPropEnt(client, Prop_Send, "m_hActiveWeapon", weapon);
                }
            }
        }  
    }
    return Plugin_Continue;
}


// 击杀事件
public Action PlayerDeath(Event event, const char[] name, bool dontBroadcast)
{
    new victim = GetClientOfUserId(event.GetInt("userid"));
    int attacker = GetClientOfUserId(event.GetInt("attacker"));
    char sWeapon[32];
    GetEventString(event, "weapon", sWeapon, sizeof(sWeapon));
    TrimString(sWeapon);    
    // PrintToChatAll("武器：%s", sWeapon);
    
    if(attacker <= 0 || attacker > MaxClients || !IsClientConnected(attacker) || !IsClientInGame(attacker))
        return Plugin_Continue;

    if(isEnabled == true && WeaponsCount >= 3 && victim != attacker)
    {
        if(BotsUse == false && IsFakeClient(attacker))
            return Plugin_Continue; 
        if(FrozenStatistic == true)
            return Plugin_Continue; 
        
        char classname[32];
        GetEdictClassname(attacker, classname, sizeof(classname));
        if(attacker > 0 && attacker <= MaxClients && StrEqual(classname, "player"))
        {
            int num0 = PlayerWeaponList[attacker];
            int num02 = PlayerWeaponList2[attacker];
            
            bool WeaponFlag = false;    // 杀敌的武器是否是玩家当前应该装备的军备竞赛武器的标志
            bool WeaponFlag2 = false; 
            if(StrEqual(sWeapon, WeaponName[num0]))
                WeaponFlag = true;
            else if (StrEqual(sWeapon, WeaponName2[num02]))
                WeaponFlag2 = true;
            else
            {
                // 手雷杀敌作特殊处理
                if(StrEqual(sWeapon, "hegrenade"))
                {
                    new currentWeapon = GetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon");
                    if (IsValidEdict(currentWeapon) && (currentWeapon > 0))
                    {
                        decl String:sWeapon2[32];
                        GetEdictClassname(currentWeapon, sWeapon2, sizeof(sWeapon2));
                        ReplaceStringEx(sWeapon2, strlen(sWeapon2), "weapon_", "");
                        TrimString(sWeapon2);
                        
                        if(StrEqual(sWeapon2, WeaponName[num0]))    // 针对带有下挂式榴弹发射器的步枪发射的枪榴弹杀敌
                            WeaponFlag = true;
                    }
                }
            }
            
            // 如果杀敌的武器是玩家当前应该装备的军备竞赛武器
            if(IsClientConnected(attacker) && IsClientInGame(attacker) && WeaponFlag == true)
            {               
                PlayerNumberOfKills[attacker] ++;    // 玩家当前军备竞赛武器杀敌数增加
                
                // 如果当前武器杀敌数已达标
                if(PlayerNumberOfKills[attacker] == SpecifiedNumberOfKills[num0])
                {
                    // 根据军备竞赛获取武器的顺序判定
                    if(GunOrder == false)
                        PlayerWeaponList[attacker] ++;
                    else
                    {
                        PlayerWeaponList[attacker] --;
                    }
                    
                    // 如果已经是最后一种武器，且符合其他条件，则结束本轮军备竞赛
                    if((GunOrder == false && PlayerWeaponList[attacker] == WeaponsCount) || (GunOrder == true && PlayerWeaponList[attacker] < 0))
                    {
                        if(!IsFakeClient(attacker) || (BotsUse == true && BotWin == true && IsFakeClient(attacker)))
                        {
                            FrozenStatistic = true;    // 冻结统计
                            if(EndType == 0)    // 进入下一回合
                            {
                                // 显示提示文字
                                char TempName[64];
                                GetClientName(attacker, TempName, sizeof(TempName));
                                
                                char PreStr[256];
                                Format(PreStr, sizeof(PreStr), "%s%s%s", "Player ", TempName, " wins the GunGame! Round restarting in 10 seconds!");
                                TrimString(PreStr);
                                
                                // PrintCenterTextAll(PreStr);
                                PrintHintTextToAll(PreStr);
                                
                                // 播放提示声音
                                for(new i = 1;i <=MaxClients;i++)
                                {
                                    if(!IsValidEntity(i))
                                        continue;
                                    
                                    char classname2[32];
                                    GetEdictClassname(i, classname2, sizeof(classname2));
                                    if(!StrEqual(classname2, "player"))
                                        continue;
                                    
                                    if(IsClientConnected(i) && IsClientInGame(i))
                                    {
                                        CreateTimer(1.0, Timer_PlayerTipSound, i);
                                    }
                                }
                                
                                CreateTimer(9.0, Timer_RemoveWeapons, attacker);    // 卸下主武器和副武器
                                
                                // 设置结束后的原因
                                int type = -1;
                                if(GetClientTeam(attacker) == CS_TEAM_CT)
                                {
                                    type = 0;
                                    CreateTimer(10.0, Timer_NextRound, type);
                                }   
                                else if(GetClientTeam(attacker) == CS_TEAM_T)
                                {
                                    type = 1;
                                    CreateTimer(10.0, Timer_NextRound, type);
                                }
                                else
                                {
                                    type = 2;
                                    CreateTimer(10.0, Timer_NextRound, type);
                                }
                                return Plugin_Continue;
                            }
                            else if(EndType == 1)   // 重启此地图
                            {
                                // 显示提示文字
                                char TempName[64];
                                GetClientName(attacker, TempName, sizeof(TempName));
                                
                                char PreStr[192];
                                Format(PreStr, sizeof(PreStr), "%s%s%s", "Player ", TempName, " wins the GunGame! Map restarting in 10 seconds!");
                                TrimString(PreStr);
                                
                                // PrintCenterTextAll(PreStr);
                                PrintHintTextToAll(PreStr);
                                
                                // 播放提示声音
                                for(new i = 1;i <=MaxClients;i++)
                                {
                                    if(!IsValidEntity(i))
                                        continue;
                                    
                                    char classname2[32];
                                    GetEdictClassname(i, classname2, sizeof(classname2));
                                    if(!StrEqual(classname2, "player"))
                                        continue;
                                    
                                    if(IsClientConnected(i) && IsClientInGame(i))
                                    {
                                        CreateTimer(1.0, Timer_PlayerTipSound, i);
                                    }
                                }
                                
                                
                                CreateTimer(10.0, Timer_ReStartMap, _);
                                return Plugin_Continue;
                            }
                            else   // 进入随机地图
                            {
                                // 显示提示文字
                                char TempName[64];
                                GetClientName(attacker, TempName, sizeof(TempName));
                                
                                char PreStr[192];
                                Format(PreStr, sizeof(PreStr), "%s%s%s", "Player ", TempName, " wins the GunGame! A random map will start in 10 seconds!");
                                TrimString(PreStr);
                                
                                // PrintCenterTextAll(PreStr);
                                PrintHintTextToAll(PreStr);
                                
                                // 播放提示声音
                                for(new i = 1;i <=MaxClients;i++)
                                {
                                    if(!IsValidEntity(i))
                                        continue;
                                    
                                    char classname2[32];
                                    GetEdictClassname(i, classname2, sizeof(classname2));
                                    if(!StrEqual(classname2, "player"))
                                        continue;
                                    
                                    if(IsClientConnected(i) && IsClientInGame(i))
                                    {
                                        CreateTimer(1.0, Timer_PlayerTipSound, i);
                                    }
                                }
                                
                                CreateTimer(10.0, Timer_RandomMap, _);
                                return Plugin_Continue;
                            }
                        }
                        else
                            return Plugin_Continue;
                    }
                    else    // 如果不是最后一种武器，则获取下一种武器
                    {
                        if(PlayerWeaponList[attacker] < 0)
                            PlayerWeaponList[attacker] = 0;
                        
                        int num = PlayerWeaponList[attacker];    // 获取玩家当前应该装备的军备竞赛武器
                        
                        if(StrEqual("", WeaponFatherName[num]))    // 如果要获取的下一种武器是原版武器
                        {
                            new ThisSlot = GetPlayerWeaponSlot(attacker, WeaponSlot[num]);
                            if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                                AcceptEntityInput(ThisSlot, "kill");
                            if(!StrEqual("", WeaponName[num]))
                            {
                                char PreStr0[] = "weapon_";
                                char NewWeaponName[32];
                                Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName[num]);
                                TrimString(NewWeaponName);
                                
                                new weapon = CreateEntityByName(NewWeaponName);
                                DispatchSpawn(weapon);
                                ActivateEntity(weapon);
                                EquipPlayerWeapon(attacker,weapon); 
                                if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                                {
                                    new MyWeaponType = GetEntProp(weapon, Prop_Data, "m_iPrimaryAmmoType");
                                    if(GetEntProp(attacker, Prop_Data, "m_iAmmo", 4, MyWeaponType) <= 0)
                                    {
                                        SetEntProp(attacker, Prop_Data, "m_iAmmo", WeaponAmmo[num], 4, MyWeaponType); 
                                    }
                                }
                                
                                // 移除其他多余的武器（近战武器和投掷武器除外）
                                if(WeaponSlot[num] == 0)
                                {
                                    int SecWeapon = GetPlayerWeaponSlot(attacker, 1);
                                    if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                                        AcceptEntityInput(SecWeapon, "kill");
                                }
                                else if(WeaponSlot[num] == 1)
                                {
                                    int MainWeapon = GetPlayerWeaponSlot(attacker, 0);
                                    if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                                        AcceptEntityInput(MainWeapon, "kill");
                                    
                                    char WeaponStr[64];
                                    Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                                    TrimString(WeaponStr);
                                    FakeClientCommand(attacker, "use %s", WeaponStr);
                                    if(IsFakeClient(attacker))
                                        SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);
                                }
                                else
                                {
                                    int MainWeapon = GetPlayerWeaponSlot(attacker, 0);
                                    int SecWeapon = GetPlayerWeaponSlot(attacker, 1);
                                    if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                                        AcceptEntityInput(MainWeapon, "kill");
                                    if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                                        AcceptEntityInput(SecWeapon, "kill");
                                    
                                    char WeaponStr[64];
                                    Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                                    TrimString(WeaponStr);
                                    FakeClientCommand(attacker, "use %s", WeaponStr);
                                    if(IsFakeClient(attacker))
                                        SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);
                                }
                                
                                // 显示提示文字
                                char PreStr[192];
                                if(!StrEqual("", WeaponDisplayName[num]))
                                    Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponDisplayName[num], "! New kill requirement: ", SpecifiedNumberOfKills[num]);
                                else
                                    Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponName[num], "! New kill requirement: ", SpecifiedNumberOfKills[num]);
                                TrimString(PreStr);
                                // PrintCenterText(attacker, PreStr);
                                PrintHintText(attacker, PreStr);
                                
                                // 播放提示音
                                if(IsPlayTipSound == true)
                                    CreateTimer(0.75, Timer_PlayerTipSound, attacker);
                            }
                            
                        }
                        else    // 如果要获取的下一种武器是加枪插件添加的武器
                        {
                            new ThisSlot = GetPlayerWeaponSlot(attacker, WeaponSlot[num]);
                            if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                                AcceptEntityInput(ThisSlot, "kill");
                            if(!StrEqual("", WeaponName[num]))
                            {
                                char PreStr0[] = "weapon_";
                                char NewWeaponName[32];
                                Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName[num]);
                                TrimString(NewWeaponName);
                                
                                char NewFatherWeaponName[32];
                                Format(NewFatherWeaponName, sizeof(NewFatherWeaponName), "%s%s", PreStr0, WeaponFatherName[num]);
                                TrimString(NewFatherWeaponName);
                                
                                new weapon = CreateEntityByName(NewFatherWeaponName);
                                DispatchKeyValue(weapon,"classname",NewWeaponName);
                                if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                                {
                                    char NewAmmo[10];
                                    IntToString(WeaponAmmo[num], NewAmmo, sizeof(NewAmmo));
                                    TrimString(NewAmmo);        
                                    DispatchKeyValue(weapon,"ammo",NewAmmo);
                                }
                                DispatchSpawn(weapon);
                                ActivateEntity(weapon);
                                EquipPlayerWeapon(attacker,weapon); 
                                if(WeaponAmmo[num] > 0 && WeaponSlot[num]!= 2)
                                {
                                    new MyWeaponType = GetEntProp(weapon, Prop_Data, "m_iPrimaryAmmoType");
                                    if(GetEntProp(attacker, Prop_Data, "m_iAmmo", 4, MyWeaponType) <= 0)
                                    {
                                        SetEntProp(attacker, Prop_Data, "m_iAmmo", WeaponAmmo[num], 4, MyWeaponType); 
                                    }
                                }
                                
                                // 移除其他多余的武器（近战武器和投掷武器除外）
                                if(WeaponSlot[num] == 0)
                                {
                                    int SecWeapon = GetPlayerWeaponSlot(attacker, 1);
                                    if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                                        AcceptEntityInput(SecWeapon, "kill");
                                }
                                else if(WeaponSlot[num] == 1)
                                {
                                    int MainWeapon = GetPlayerWeaponSlot(attacker, 0);
                                    if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                                        AcceptEntityInput(MainWeapon, "kill");

                                    char WeaponStr[64];
                                    Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                                    TrimString(WeaponStr);
                                    FakeClientCommand(attacker, "use %s", WeaponStr);
                                    if(IsFakeClient(attacker))
                                        SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);
                                }
                                else
                                {
                                    int MainWeapon = GetPlayerWeaponSlot(attacker, 0);
                                    int SecWeapon = GetPlayerWeaponSlot(attacker, 1);
                                    if(IsValidEdict(MainWeapon) && MainWeapon > -1)
                                        AcceptEntityInput(MainWeapon, "kill");
                                    if(IsValidEdict(SecWeapon) && SecWeapon > -1)
                                        AcceptEntityInput(SecWeapon, "kill");
                                    
                                    char WeaponStr[64];
                                    Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                                    TrimString(WeaponStr);
                                    FakeClientCommand(attacker, "use %s", WeaponStr);
                                    if(IsFakeClient(attacker))
                                        SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);
                                }
                                
                                // 显示提示文字
                                char PreStr[128];
                                if(!StrEqual("", WeaponDisplayName[num]))
                                    Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponDisplayName[num], "! New kill requirement: ", SpecifiedNumberOfKills[num]);
                                else
                                    Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponName[num], "! New kill requirement: ", SpecifiedNumberOfKills[num]);
                                TrimString(PreStr);
                                // PrintCenterText(attacker, PreStr);
                                PrintHintText(attacker, PreStr);
                                
                                // 播放提示音
                                if(IsPlayTipSound == true)
                                    CreateTimer(0.75, Timer_PlayerTipSound, attacker);
                            }
                        }
                        PlayerNumberOfKills[attacker] = 0;    // 当前武器杀敌数清零
                    }
                }
                else
                {
                    // 显示提示文字
                    char PreStr[32];
                    Format(PreStr, sizeof(PreStr), "%s%d", "Kill requirement remaining: ", SpecifiedNumberOfKills[num0] - PlayerNumberOfKills[attacker]);
                    TrimString(PreStr);
                    // PrintCenterText(attacker, PreStr);
                    PrintHintText(attacker, PreStr);
                    
                    // 播放提示音
                    if(IsPlayTipSound == true)
                        CreateTimer(0.75, Timer_PlayerTipSound, attacker); 
                }
            }

            // 刀具单独
            if(IsClientConnected(attacker) && IsClientInGame(attacker) && WeaponFlag2 == true)
            {               
                PlayerNumberOfKills2[attacker] ++;    // 玩家当前军备竞赛武器杀敌数增加
                
                // 如果当前武器杀敌数已达标
                if(PlayerNumberOfKills2[attacker] == SpecifiedNumberOfKills2[num02])
                {
                    // 根据军备竞赛获取武器的顺序判定
                    if(GunOrder == false)
                        PlayerWeaponList2[attacker] ++;
                    else
                    {
                        PlayerWeaponList2[attacker] --;
                    }
                    
                    // 如果已经是最后一种武器，什么都不做
                    if((GunOrder == false && PlayerWeaponList2[attacker] == WeaponsCount2) || (GunOrder == true && PlayerWeaponList2[attacker] < 0))
                    {
                        PlayerNumberOfKills2[attacker] --; 

                        if(GunOrder == false)
                            PlayerWeaponList2[attacker] --;
                        else
                        {
                            PlayerWeaponList2[attacker] ++;
                        }

                        PrintHintText(attacker, "Melee weapons have upgraded to the top tier");
                        return Plugin_Continue;
                    }
                    else    // 如果不是最后一种武器，则获取下一种武器
                    {
                        CreateTimer(0.5, Timer_GiveKnife, attacker);

                        // if(PlayerWeaponList2[attacker] < 0)
                        //     PlayerWeaponList2[attacker] = 0;
                        
                        // int num = PlayerWeaponList2[attacker];    // 获取玩家当前应该装备的军备竞赛武器
                        
                        // if(StrEqual("knife", WeaponName2[num]))    // 如果要获取的下一种武器是原版武器
                        // {
                        //     new ThisSlot = GetPlayerWeaponSlot(attacker, 2);
                        //     if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                        //         AcceptEntityInput(ThisSlot, "kill");
                            
                        //     new weapon = CreateEntityByName("weapon_knife");

                        //     DispatchSpawn(weapon);
                        //     ActivateEntity(weapon);
                        //     EquipPlayerWeapon(attacker,weapon);

                        //     char WeaponStr[64];
                        //     Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        //     TrimString(WeaponStr);
                        //     FakeClientCommand(attacker, "use %s", WeaponStr);
                        //     if(IsFakeClient(attacker))
                        //         SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);

                        //     // 显示提示文字
                        //     char PreStr[192];
                        //     if(!StrEqual("", WeaponDisplayName2[num]))
                        //         Format(PreStr, sizeof(PreStr), "%s%s%s%d", "获得新武器：", WeaponDisplayName2[num], "！新武器杀敌数量要求：", SpecifiedNumberOfKills2[num]);
                        //     else
                        //         Format(PreStr, sizeof(PreStr), "%s%s%s%d", "获得新武器：", WeaponName2[num], "！新武器杀敌数量要求：", SpecifiedNumberOfKills2[num]);
                        //     TrimString(PreStr);
                        //     // PrintCenterText(attacker, PreStr);
                        //     PrintHintText(attacker, PreStr);

                        //     // 播放提示音
                        //     if(IsPlayTipSound == true)
                        //         CreateTimer(0.75, Timer_PlayerTipSound, attacker);
                        // }
                        // else    // 如果要获取的下一种武器是加枪插件添加的武器
                        // {
                        //     new ThisSlot = GetPlayerWeaponSlot(attacker, 2);
                        //     if(IsValidEdict(ThisSlot) && ThisSlot > -1)
                        //         AcceptEntityInput(ThisSlot, "kill");
                        //     if(!StrEqual("", WeaponName2[num]))
                        //     {
                        //         char PreStr0[] = "weapon_";
                        //         char NewWeaponName[32];
                        //         Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName2[num]);
                        //         TrimString(NewWeaponName);
                                
                        //         new weapon = CreateEntityByName("weapon_knife");
                        //         DispatchKeyValue(weapon,"classname",NewWeaponName);
       
                        //         DispatchSpawn(weapon);
                        //         ActivateEntity(weapon);
                        //         EquipPlayerWeapon(attacker,weapon);

                        //         char WeaponStr[64];
                        //         Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
                        //         TrimString(WeaponStr);
                        //         FakeClientCommand(attacker, "use %s", WeaponStr);
                        //         if(IsFakeClient(attacker))
                        //             SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);

                        //         char PreStr[128];
                        //         if(!StrEqual("", WeaponDisplayName2[num]))
                        //             Format(PreStr, sizeof(PreStr), "%s%s%s%d", "获得新武器：", WeaponDisplayName2[num], "！新武器杀敌数量要求：", SpecifiedNumberOfKills2[num]);
                        //         else
                        //             Format(PreStr, sizeof(PreStr), "%s%s%s%d", "获得新武器：", WeaponName2[num], "！新武器杀敌数量要求：", SpecifiedNumberOfKills2[num]);
                        //         TrimString(PreStr);
                        //         // PrintCenterText(attacker, PreStr);
                        //         PrintHintText(attacker, PreStr); 

                        //         // 播放提示音
                        //         if(IsPlayTipSound == true)
                        //             CreateTimer(0.75, Timer_PlayerTipSound, attacker);
                        //     }
                        // }

                        // PlayerNumberOfKills2[attacker] = 0;    // 当前武器杀敌数清零
                    }
                }
                else
                {
                    // 显示提示文字
                    char PreStr[32];
                    Format(PreStr, sizeof(PreStr), "%s%d", "Kill requirement remaining: ", SpecifiedNumberOfKills2[num02] - PlayerNumberOfKills2[attacker]);
                    TrimString(PreStr);
                    // PrintCenterText(attacker, PreStr);
                    PrintHintText(attacker, PreStr);
                    
                    // 播放提示音
                    if(IsPlayTipSound == true)
                        CreateTimer(0.75, Timer_PlayerTipSound, attacker); 
                }
            }
        }
    }
    return Plugin_Continue; 
}


public Action:Timer_GiveKnife(Handle timer, int attacker)
{
    if(PlayerWeaponList2[attacker] < 0)
        PlayerWeaponList2[attacker] = 0;
    
    int num = PlayerWeaponList2[attacker];    // 获取玩家当前应该装备的军备竞赛武器
    
    if(StrEqual("knife", WeaponName2[num]))    // 如果要获取的下一种武器是原版武器
    {
        new ThisSlot = GetPlayerWeaponSlot(attacker, 2);
        if(IsValidEdict(ThisSlot) && ThisSlot > -1)
            AcceptEntityInput(ThisSlot, "kill");
        
        new weapon = CreateEntityByName("weapon_knife");

        DispatchSpawn(weapon);
        ActivateEntity(weapon);
        EquipPlayerWeapon(attacker,weapon);

        char WeaponStr[64];
        Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
        TrimString(WeaponStr);
        FakeClientCommand(attacker, "use %s", WeaponStr);
        if(IsFakeClient(attacker))
            SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);

        // 显示提示文字
        char PreStr[192];
        if(!StrEqual("", WeaponDisplayName2[num]))
            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponDisplayName2[num], "! New kill requirement: ", SpecifiedNumberOfKills2[num]);
        else
            Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponName2[num], "! New kill requirement: ", SpecifiedNumberOfKills2[num]);
        TrimString(PreStr);
        // PrintCenterText(attacker, PreStr);
        PrintHintText(attacker, PreStr);

        // 播放提示音
        if(IsPlayTipSound == true)
            CreateTimer(0.75, Timer_PlayerTipSound, attacker);
    }
    else    // 如果要获取的下一种武器是加枪插件添加的武器
    {
        new ThisSlot = GetPlayerWeaponSlot(attacker, 2);
        if(IsValidEdict(ThisSlot) && ThisSlot > -1)
            AcceptEntityInput(ThisSlot, "kill");
        if(!StrEqual("", WeaponName2[num]))
        {
            char PreStr0[] = "weapon_";
            char NewWeaponName[32];
            Format(NewWeaponName, sizeof(NewWeaponName), "%s%s", PreStr0, WeaponName2[num]);
            TrimString(NewWeaponName);
            
            new weapon = CreateEntityByName("weapon_knife");
            DispatchKeyValue(weapon,"classname",NewWeaponName);

            DispatchSpawn(weapon);
            ActivateEntity(weapon);
            EquipPlayerWeapon(attacker,weapon);

            char WeaponStr[64];
            Format(WeaponStr, sizeof(WeaponStr), "%s%s", "weapon_", WeaponName[num]);
            TrimString(WeaponStr);
            FakeClientCommand(attacker, "use %s", WeaponStr);
            if(IsFakeClient(attacker))
                SetEntPropEnt(attacker, Prop_Send, "m_hActiveWeapon", weapon);

            char PreStr[128];
            if(!StrEqual("", WeaponDisplayName2[num]))
                Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponDisplayName2[num], "! New kill requirement: ", SpecifiedNumberOfKills2[num]);
            else
                Format(PreStr, sizeof(PreStr), "%s%s%s%d", "New weapon obtained: ", WeaponName2[num], "! New kill requirement: ", SpecifiedNumberOfKills2[num]);
            TrimString(PreStr);
            // PrintCenterText(attacker, PreStr);
            PrintHintText(attacker, PreStr); 

            // 播放提示音
            if(IsPlayTipSound == true)
                CreateTimer(0.75, Timer_PlayerTipSound, attacker);
        }
    }

    PlayerNumberOfKills2[attacker] = 0;    // 当前武器杀敌数清零

    return Plugin_Continue;
}


// 开始下一回合
public Action:Timer_NextRound(Handle timer, int type)
{
    if(type == 0)
    {
        CS_TerminateRound(3.0, CSRoundEnd_CTWin);
        int CTScore = CS_GetTeamScore(CS_TEAM_CT);
        int CTScore2 = GetTeamScore(CS_TEAM_CT);
        CTScore ++;
        CTScore2 ++;
        CS_SetTeamScore(CS_TEAM_CT, CTScore);
        SetTeamScore(CS_TEAM_CT, CTScore2);
    }    
    else if(type == 1)
    {
        CS_TerminateRound(3.0, CSRoundEnd_TerroristWin);
        int TerScore = CS_GetTeamScore(CS_TEAM_T);
        int TerScore2 = GetTeamScore(CS_TEAM_T);
        TerScore ++;
        TerScore2 ++;
        CS_SetTeamScore(CS_TEAM_T, TerScore);
        SetTeamScore(CS_TEAM_T, TerScore2);
        
    }
    else
        CS_TerminateRound(3.0, CSRoundEnd_Draw);
    
    return Plugin_Continue;
}


// 重启当前地图
public Action:Timer_ReStartMap(Handle timer, any client)
{
    char map_name[MAX_NAME_LENGTH];
    GetCurrentMap(map_name, sizeof(map_name));
    ForceChangeLevel(map_name, "[SM] Restarting the map.");
    
    return Plugin_Continue;
}


// 进入随机地图
public Action:Timer_RandomMap(Handle timer, any client)
{
    if (ReadMapList(maps, serial) == null || serial == -1 || maps == INVALID_HANDLE) 
    {
        LogMessage("Random Map failed to load a map list. Serial: %i", serial);
        return Plugin_Continue;
    }

    char map[256];
    int random = GetRandomInt(0, maps.Length - 1);

    maps.GetString(random, map, sizeof(map));

    LogMessage("Changed map to %s", map);
    ServerCommand("sm_map %s", map);
    
    return Plugin_Continue;
}


// 卸下主武器和副武器
public Action:Timer_RemoveWeapons(Handle timer, int client)
{
    if(!IsValidEntity(client))
        return Plugin_Continue;
    
    if(IsClient(client, true))
    {
        int MainWeapon = GetPlayerWeaponSlot(client, 0);
        int SecWeapon = GetPlayerWeaponSlot(client, 1);
        
        if(IsValidEdict(MainWeapon) && MainWeapon > -1)
            AcceptEntityInput(MainWeapon, "kill");
        if(IsValidEdict(SecWeapon) && SecWeapon > -1)
            AcceptEntityInput(SecWeapon, "kill");
    }
    return Plugin_Continue;
}


// 播放提示声音
public Action:Timer_PlayerTipSound(Handle timer, int client)
{
    if(!IsValidEntity(client))
        return Plugin_Continue;
    
    if(IsClientConnected(client) && IsClientInGame(client))
    {
        EmitSoundToClient(client,"GunGameSound/KillTipSound.wav", client, SNDCHAN_VOICE);
    }
    return Plugin_Continue;
}


// 播放提示声音2
public Action:Timer_PlayerTipSound2(Handle timer, int client)
{
    if(!IsValidEntity(client))
        return Plugin_Continue;
    
    if(IsClientConnected(client) && IsClientInGame(client))
    {
        EmitSoundToClient(client,"UI/hint.wav", client, SNDCHAN_VOICE);
    }
    return Plugin_Continue;
}


// 禁止切换到无关武器（投掷武器除外）
public Action:Hook_WeaponCanSwitch(client, weapon)
{   
    if(isEnabled == true && WeaponsCount >= 3)
    {
        decl String:sWeapon[64];
        GetEntityClassname(weapon, sWeapon, sizeof(sWeapon));
        ReplaceStringEx(sWeapon, strlen(sWeapon), "weapon_", "");
        TrimString(sWeapon);
        
        // 不禁止切换到投掷武器（包括燃烧瓶）和火箭筒
        if(StrEqual(sWeapon, "knife") || StrEqual(sWeapon, "knife2") || StrEqual(sWeapon, "hegrenade") || StrEqual(sWeapon, "flashbang") || StrEqual(sWeapon, "smokegrenade") || StrEqual(sWeapon, "molotov") || StrEqual(sWeapon, "rpg")  || StrEqual(sWeapon, "rpg7"))
            return Plugin_Continue;
        else
        {
            if(!IsFakeClient(client))
            {
                int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
                int num2 = PlayerWeaponList2[client];
                if(StrEqual(sWeapon, WeaponName[num]) || StrEqual(sWeapon, WeaponName2[num2]))
                    return Plugin_Continue;
                else
                    return Plugin_Stop;
            }
            else
            {
                if(BotsUse == true)
                {
                    int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
                    int num2 = PlayerWeaponList2[client];
                    if(StrEqual(sWeapon, WeaponName[num]) || StrEqual(sWeapon, WeaponName2[num2]))
                        return Plugin_Continue;
                    else
                        return Plugin_Stop;
                }
            }
        }       
    }
    return Plugin_Continue;
}


// 禁止玩家购买武器
public Action CS_OnBuyCommand(int client, const char[] weapon)
{
    if(isEnabled == true && WeaponsCount >= 3)
    {
        if(StrEqual("hegrenade", weapon, false) == false && StrEqual("flashbang", weapon, false) == false && StrEqual("smokegrenade", weapon, false) == false)
        {
            if(IsClient(client,true))
            {
                if(!IsFakeClient(client))
                {
                    PrintCenterText(client, "Weapons other than grenades, smoke grenades, and flashbangs cannot be purchased in GunGame!");
                    return Plugin_Handled;
                }
                else
                {
                    if(BotsUse == true)
                        return Plugin_Handled;
                }   
            }       
        }
    }
    return Plugin_Continue;
}


// 掉落武器函数（针对真人玩家）
public Action:Command_Dorp(client, const String:cmd[], argc)
{
    if(isEnabled == true && WeaponsCount >= 3)
    {
        if(IsClient(client,true) && !IsFakeClient(client))    
        {
            PrintCenterText(client, "Dropping weapon is disabled in GunGame!");
            return Plugin_Handled;
        }
    }
    return Plugin_Continue;
}


// 掉落武器函数（针对bot）
public Action:OnWeaponDrop(client, weapon)
{
    if(isEnabled == true && WeaponsCount >= 3 && BotsUse == true)
    {
        if(IsClient(client,true) && IsFakeClient(client))
            return Plugin_Handled;
    }
    return Plugin_Continue;
}


// 禁止玩家获取无关武器
public Action:OnWeaponEquip(client, weapon)
{
    if(isEnabled == true && WeaponsCount >= 3)
    {
        if(IsClient(client,true))
        {
            decl String:sWeapon[64];
            GetEntityClassname(weapon, sWeapon, sizeof(sWeapon));
            ReplaceStringEx(sWeapon, strlen(sWeapon), "weapon_", "");
            TrimString(sWeapon);
            
            // 不禁止获取投掷武器（包括燃烧瓶）和火箭筒
            if(StrEqual(sWeapon, "knife") || StrEqual(sWeapon, "knife2") || StrEqual(sWeapon, "hegrenade") || StrEqual(sWeapon, "flashbang") || StrEqual(sWeapon, "smokegrenade") || StrEqual(sWeapon, "molotov") || StrEqual(sWeapon, "rpg")  || StrEqual(sWeapon, "rpg7"))
                return Plugin_Continue;
            
            else
            {
                if(!IsFakeClient(client))
                {
                    int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
                    int num2 = PlayerWeaponList2[client];
                    if(StrEqual(sWeapon, WeaponName[num]) || StrEqual(sWeapon, WeaponName2[num2]))
                        return Plugin_Continue;
                    else
                    {
                        PrintCenterText(client, "Weapons other than grenades, smoke grenades, and flashbangs cannot be purchased in GunGame!");
                        return Plugin_Handled;
                    }
                }
                else
                {
                    if(BotsUse == true)
                    {
                        int num = PlayerWeaponList[client];    // 获取玩家当前应该装备的军备竞赛武器
                        int num2 = PlayerWeaponList2[client];
                        if(StrEqual(sWeapon, WeaponName[num]) || StrEqual(sWeapon, WeaponName2[num2]))
                            return Plugin_Continue;
                        else
                            return Plugin_Handled;
                    }
                }
            }
        }
    }
    return Plugin_Continue;
}


