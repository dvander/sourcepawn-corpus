/* Plugin Template generated by Pawn Studio */

#include <sdktools>
#include <sourcemod>
#include <sdkhooks>
#include <cstrike>
#include <zombiereloaded>

public Plugin:myinfo = {
	name = "Block the respawning of headshot zombies",
	author = "cjsrk",
	description = "<- Description ->",
	version = "0.1",
	url = "<- URL ->"
}


bool IsHeadshot[65] = {false};


public OnPluginStart(){
	HookEvent("round_end", RoundEnd2, EventHookMode_Post);
	HookEvent("player_death", Event_PlayerDeath4, EventHookMode_Pre);
}


public OnMapStart()
{	
	for(new i = 0; i < 65; i++)
	{
		IsHeadshot[i] = false;
	}
}


public void RoundEnd2(Handle:event,const String:name[],bool:dontBroadcast)
{
	for(new i = 0; i < 65; i++)
	{
		IsHeadshot[i] = false;
	}
}


// 玩家死亡函数
public Action:Event_PlayerDeath4(Handle:event, const String:name[], bool:dontBroadcast)
{
	new victim = GetClientOfUserId(GetEventInt(event, "userid"));
	new bool: headshot = GetEventBool(event, "headshot")
	if(headshot == true)
	{
		IsHeadshot[victim] = true;
		PrintToChatAll("A zombie was shot in the head!");
	}
}


public Action ZR_OnClientRespawn(int &client, ZR_RespawnCondition &condition)
{
	if(IsHeadshot[client] == true)
	{
		// PrintToChatAll("被爆头的僵尸无法复活！");
		return Plugin_Handled;
	}
	return Plugin_Continue;
}