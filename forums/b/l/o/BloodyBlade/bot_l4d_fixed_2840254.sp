/* Plugin Template generated by Pawn Studio */
#pragma semicolon 1
#pragma newdecls required

#include <sourcemod>
#include <sdktools>
#tryinclude <left4dhooks>

#define PLUGIN_VERSION "2.0"
#define CVAR_FLAGS FCVAR_NOTIFY

ConVar l4d_bot_on, l4d_bot_max, l4d_bot_teleport;
bool bHooked = false, IsNewPlayer[MAXPLAYERS + 1] = {false, ...}, bBotTeleport = false;
int iBotMax = 0;
Handle hSpec = null, hSwitch = null, hRoundRespawn = null;
#if defined _l4dh_included
bool bL4DHLib = false;
bool bLateload = false;
#endif

public Plugin myinfo = 
{
	name = "[L4D] Bots Control In Coop Mode",
	author = "Pan XiaoHai, fix by raziEiL [disawar1], BloodyBlade",
	description = "<- Description ->",
	version = PLUGIN_VERSION,
	url = "<- URL ->"
}

public APLRes AskPluginLoad2(Handle myself, bool late, char[] error, int err_max)
{
    EngineVersion engine = GetEngineVersion();
    if (engine != Engine_Left4Dead && engine != Engine_Left4Dead2)
    {
        strcopy(error, err_max, "This plugin only runs in \"Left 4 Dead\" game series");
        return APLRes_SilentFailure;
    }

    #if defined _l4dh_included
    bLateload = late;
    #endif

    return APLRes_Success;
}

public void OnPluginStart()
{
    CreateConVar("l4d_bot_version", PLUGIN_VERSION, "[L4D] Bots Control In Coop Mode plugin version", CVAR_FLAGS|FCVAR_DONTRECORD);
    l4d_bot_on = CreateConVar("l4d_bot_on", "1", "Enable/Disable plugin", CVAR_FLAGS);
    l4d_bot_max = CreateConVar("l4d_bot_max", "8", "max bots", CVAR_FLAGS);
    l4d_bot_teleport = CreateConVar("l4d_bot_teleport", "1", "teleport the new bot to a palyer", CVAR_FLAGS);

    AutoExecConfig(true, "l4d_bot");

    l4d_bot_on.AddChangeHook(OnConVarEnableChanged);
    l4d_bot_max.AddChangeHook(OnConVarsChanged);
    l4d_bot_teleport.AddChangeHook(OnConVarsChanged);

    RegAdminCmd("sm_bot", sm_bot123, ADMFLAG_UNBAN); 
    RegAdminCmd("sm_addbot", add_bot, ADMFLAG_UNBAN);

    #if defined _l4dh_included
    if(bLateload)
    {
        bL4DHLib = LibraryExists("left4dhooks");
    }
    #else
    GameData hGameConf = LoadGameConfigFile("l4d_bot");
    if(hGameConf == null) PrintToChatAll("load error");

    StartPrepSDKCall(SDKCall_Player);
    PrepSDKCall_SetFromConf(hGameConf, SDKConf_Signature, "SetHumanSpec");
    PrepSDKCall_AddParameter(SDKType_CBasePlayer, SDKPass_Pointer);
    hSpec = EndPrepSDKCall();
    if (hSpec == null) 
    { 
        PrintToServer("SetHumanSpec Signature broken");
    }

    StartPrepSDKCall(SDKCall_Player);
    PrepSDKCall_SetFromConf(hGameConf, SDKConf_Signature, "TakeOverBot");
    PrepSDKCall_AddParameter(SDKType_Bool, SDKPass_Plain);
    hSwitch = EndPrepSDKCall();
    if (hSwitch == null) 
    { 
        PrintToServer("TakeOverBot Signature broken");
    }

    StartPrepSDKCall(SDKCall_Player);
    PrepSDKCall_SetFromConf(hGameConf, SDKConf_Signature, "RoundRespawn");
    hRoundRespawn = EndPrepSDKCall();  
    if (hRoundRespawn == null) 
    { 
        PrintToServer("RoundRespawn Signature broken");
    }
    #endif
}

#if defined _l4dh_included
public void OnLibraryAdded(const char[] name)
{
	if(strcmp(name, "left4dhooks") == 0)
	{
		bL4DHLib = true;
	}
}

public void OnLibraryRemoved(const char[] name)
{
	if(strcmp(name, "left4dhooks") == 0)
	{
		bL4DHLib = false;
	}
}
#endif

public void OnConfigsExecuted()
{
	IsAllowed();
}

void OnConVarEnableChanged(ConVar cvar, const char[] oldVal, const char[] newVal)
{
	IsAllowed();
}

void OnConVarsChanged(ConVar cvar, const char[] oldVal, const char[] newVal)
{
    iBotMax = l4d_bot_max.IntValue;
    bBotTeleport = l4d_bot_teleport.BoolValue;
}

void IsAllowed()
{
    bool bPluginOn = l4d_bot_on.BoolValue;
    if(!bHooked && bPluginOn)
    {
        bHooked = true;
        OnConVarsChanged(null, "", "");
        HookEvent("player_spawn", Events);
        HookEvent("player_team", Events);
        HookEvent("player_death", Events);
        HookEvent("player_bot_replace", Events);
    }
    else if(bHooked && !bPluginOn)
    {
        bHooked = false;
        UnhookEvent("player_spawn", Events);
        UnhookEvent("player_team", Events);
        UnhookEvent("player_death", Events);
        UnhookEvent("player_bot_replace", Events);
    }
}

public void OnClientPutInServer(int client)
{
	if(client > 0 && !IsFakeClient(client)) 
	{
		//PrintToServer("OnClientPutInServer %N", client );
		IsNewPlayer[client] = true;
		int bot = GetSurvivorCount();
		int player = GetRealPlayerCount();
		PrintToServer("client %N join game bot %d human %d", client,bot ,player);
		if(bot < player && bot < iBotMax)
		{
			MakeBot(client, false);
		}
	}
}

Action Events(Event event, char[] name, bool dontBroadcast)
{
    if (strcmp(name, "player_spawn") == 0)
    {
        int client = GetClientOfUserId(event.GetInt("userid")); 
        if(client > 0 && IsClientInGame(client) && GetClientTeam(client) == 2 && !IsFakeClient(client)) 
        {
            SetAliveState(client, true); 
        }
    }
    else if(strcmp(name, "player_team") == 0)
    {
        int client = GetClientOfUserId(event.GetInt("userid")); 
        int team =  event.GetInt("team");
        int isnew = IsNewPlayer[client];
        IsNewPlayer[client] = false;  
        if(isnew && client > 0 && IsClientInGame(client) && !IsFakeClient(client))
        {
            if(client > 0 && IsClientInGame(client) && !IsFakeClient(client)) PrintToServer("player %N change team to %d", client, team);
            CreateTimer(1.0, ClientInServer, client);	 
        }
    }
    else if(strcmp(name, "player_death") == 0)
    {
        int client = GetClientOfUserId(event.GetInt("userid")); 
        if(client > 0 && IsClientInGame(client) && GetClientTeam(client) == 2 && !IsFakeClient(client)) 
        {
            SetAliveState(client, false); 
        }
    }
    else if(strcmp(name, "player_bot_replace") == 0)
    {
        int bot = GetClientOfUserId(event.GetInt("bot"));
        if(bot > 0 && IsClientInGame(bot) && GetClientTeam(bot) == 2)
        {
            CreateTimer(3.0, TimerKick, bot); 
        }
    }
    return Plugin_Continue;
}

Action ClientInServer(Handle timer, int client)
{
    if(client > 0 && IsClientInGame(client) && !IsFakeClient(client))
    {
        PrintToServer("player %N join survivor", client );
        if (GetClientTeam(client) == 1)
        {			
            int bot = GetABot();
            if(bot > 0)
            {
                TakeOverBot(client, bot);
                PrintToServer("player %N takeover %N ", client,bot );
            }
        }

        bool bstate = GetAliveState(client); 
        if(bstate && !IsPlayerAlive(client))
        {
            Respawn(client);
            PrintToServer("force player %N respawn",client);
        }

        if (bBotTeleport)
        {
            CreateTimer(0.1, TeleMe, client);
        }		
    }
    return Plugin_Stop;
}

Action TeleMe(Handle timer, int client)
{
	if (IsClientInGame(client))
	{
		TeleportClientTo(client);
	}
	return Plugin_Handled;
}

void TeleportClientTo(int client)
{
	for(int i = 1; i <= MaxClients; i++)
	{
		if (i != client && IsClientInGame(i) && GetClientTeam(i) == 2 && IsPlayerAlive(i))
		{
			float pos[3];
			GetClientAbsOrigin(i, pos);
			TeleportEntity(client, pos, NULL_VECTOR,NULL_VECTOR);
			//PrintToChatAll("tele %N to %N", client, i)
			break;
		}
	}
}

int GetSurvivorCount()
{
	int count = 0;
	for(int i = 1; i <= MaxClients; i++)
	{
		if (IsClientInGame(i) && GetClientTeam(i) == 2)
		{
			count++;
		} 
	}	
	return count;
}

int GetABot()
{
	int r = 0;
	int bots = 0;
	for(int i = 1; i <= MaxClients; i++)
	{
		if (IsClientInGame(i) && GetClientTeam(i) == 2) 
		{
			if(IsFakeClient(i)) r = i;
			bots++;
		} 
	}	  
	return r;
}

Action TimerKick(Handle timer, any bot)
{
	if(GetSurvivorCount() <= 4)
    {
		return Plugin_Stop;
    }

	if (IsClientConnected(bot) && IsClientInGame(bot))
	{
		KickClient(bot, "fake player");
	}
	return Plugin_Stop;
}

int GetRealPlayerCount(int except = 0)
{
	int count = 0;
	for(int i = 1; i <= MaxClients; i++)
	{
		if (IsClientInGame(i) && GetClientTeam(i) != 3 && !IsFakeClient(i) && i != except)
		{
			count++;
		} 
	}
	return count;
}

Action add_bot(int client, int args)
{
	MakeBot(client, true);
	return Plugin_Handled;
} 

Action sm_bot123(int client, int args)
{
    Respawn(client);
    return Plugin_Handled;
}

stock void TakeOverBot(int client, int bot)
{
    #if defined _l4dh_included
    L4D_SetHumanSpec(bot, client);
    L4D_TakeOverBot(client);
    #else
    SDKCall(hSpec, bot, client);
    SDKCall(hSwitch, client, true);
    #endif
}

stock void Respawn(int client)
{
    #if defined _l4dh_included
    L4D_RespawnPlayer(client);
    #else
    SDKCall(hRoundRespawn, client);
    #endif
}

void SetAliveState(int client, bool bstate)
{
	if(bstate) ClientCommand(client, "setinfo %s %s", "alive", "true"); 	
	else ClientCommand(client, "setinfo %s %s", "alive", "false"); 	
}

bool GetAliveState(int client)
{
	char info[64];
	GetClientInfo(client, "alive", info, 64);
	PrintToServer("palyer %N info %s", client, info);
	if(StrEqual(info, "false"))	return false;
	return true;
}

int MakeBot(int client = 0, bool bPrintToClient = false)
{
	int bot = CreateFakeClient("I am not real.");
	if(bot != 0)
	{
		ChangeClientTeam(bot, 2);
		if(DispatchKeyValue(bot, "classname", "SurvivorBot") == false)
		{
			PrintToServer("\x01Create bot failed");
			return 0;
		}

		if(DispatchSpawn(bot) == false)
		{
			PrintToServer("\x01Create bot failed");
			return 0;
		}

		SetEntityRenderColor(bot, 128, 0, 0, 255); 
		CreateTimer(0.1,TimerKick, bot, TIMER_FLAG_NO_MAPCHANGE); 
		if(client > 0 && bPrintToClient) PrintToChatAll("Create a bot for %N", client);
		if(client > 0) PrintToServer("Create a bot for %N", client);

		TeleportClientTo(bot);
	}
	return bot;
}
