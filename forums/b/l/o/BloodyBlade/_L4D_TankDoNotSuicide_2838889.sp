/* Plugin Template generated by Pawn Studio */
#pragma semicolon 1
#pragma newdecls required
#include <sourcemod>
#include <sdktools>
#tryinclude <left4dhooks>
 
#define PLUGIN_VERSION "1.0"
#define CVAR_FLAGS FCVAR_NOTIFY

public Plugin myinfo = 
{
	name = "[L4D] Prevent Tank From Suicide",
	author = "Pan XiaoHai",
	description = "<- Description ->",
	version = "1.0",
	url = "<- URL ->"
}

ConVar hPluginOn;
bool bL4D2 = false, bLateload = false, bHooked = false;
#if defined _l4dh_included
bool bL4DHLib = false;
#endif
int zClassTank = 0;

public APLRes AskPluginLoad2(Handle myself, bool late, char[] error, int err_max)
{
	EngineVersion engine = GetEngineVersion();
	if (engine == Engine_Left4Dead)
	{
		bL4D2 = false;
		zClassTank = 5;
	}
	else if(engine == Engine_Left4Dead2)
	{
		bL4D2 = true;
		zClassTank = 8;
	}
	else
	{
		strcopy(error, err_max, "This plugin only runs in \"Left 4 Dead\" game series");
		return APLRes_SilentFailure;
	}

	#if defined _l4dh_included
	bLateload = late;
	#endif

	return APLRes_Success;
}

public void OnPluginStart()
{
	CreateConVar("l4d_tank_donote_suicide_version", PLUGIN_VERSION, "[L4D] Prevent Tank From Suicide plugin version", CVAR_FLAGS|FCVAR_SPONLY|FCVAR_DONTRECORD);
	hPluginOn = CreateConVar("l4d_tank_donote_suicide_enable", "1", "Enables this plugin.", CVAR_FLAGS, true, 0.0, true, 1.0);

	AutoExecConfig(true, "tank_donote_suicide");

	hPluginOn.AddChangeHook(OnConVarPluginOnChange);

	#if defined _l4dh_included
	if(bLateload)
	{
		bL4DHLib = LibraryExists("left4dhooks");
	}
	#endif
}

#if defined _l4dh_included
public void OnLibraryAdded(const char[] name)
{
	if(strcmp(name, "left4dhooks") == 0)
	{
		bL4DHLib = true;
	}
}

public void OnLibraryRemoved(const char[] name)
{
	if(strcmp(name, "left4dhooks") == 0)
	{
		bL4DHLib = false;
	}
}
#endif

public void OnConfigsExecuted()
{
	IsAllowed();
}

void OnConVarPluginOnChange(ConVar cvar, const char[] oldVal, const char[] newVal)
{
	IsAllowed();
}

void IsAllowed()
{
	bool bPluginOn = hPluginOn.BoolValue;
	if(!bHooked && bPluginOn && (L4D_IsCoopMode() || L4D2_IsRealismMode()))
	{
		HookEvent("player_incapacitated", PlayerIncapacitated);
	}
	else if(bHooked && (!bPluginOn || (!L4D_IsCoopMode() && !L4D2_IsRealismMode())))
	{
		UnhookEvent("player_incapacitated", PlayerIncapacitated);
	}
}

Action PlayerIncapacitated(Event hEvent, const char[] strName, bool DontBroadcast)
{ 
	int victim = GetClientOfUserId(hEvent.GetInt("userid"));  
	int attacker = GetClientOfUserId(hEvent.GetInt("attacker"));
	if(IsValidTank(victim) && IsValidTank(attacker) && attacker == victim)
	{
		float vecPos[3], vecAng[3]; 
		int flag = GetEntProp(victim, Prop_Send, "m_fFlags");
		int m_nSequence = GetEntProp(victim, Prop_Data, "m_nSequence");
		int m_iHealth = GetEntProp(victim, Prop_Send, "m_iHealth" );
		int m_iMaxHealth = GetEntProp(victim, Prop_Send, "m_iMaxHealth" );	
		GetEntPropVector(victim, Prop_Send, "m_vecOrigin", vecPos); 
		GetEntPropVector(victim, Prop_Send, "m_angRotation", vecAng);
		AcceptEntityInput(victim, "kill");

		
		int iNewTank = 0;
		#if defined _l4dh_included
		if(bL4D2 && bL4DHLib)
		{
			iNewTank = L4D2_SpawnTank(vecPos, vecAng);
		}
		#else
		iNewTank = CreateTank(victim);
		#endif

		if(iNewTank > 0)
		{
			SetEntProp(iNewTank, Prop_Send, "m_fFlags", flag);
			SetEntProp(iNewTank, Prop_Data, "m_nSequence",m_nSequence);		
			SetEntProp(iNewTank, Prop_Send, "m_iHealth", m_iHealth);
			SetEntProp(iNewTank, Prop_Send, "m_iMaxHealth", m_iMaxHealth);	
			PrintToChatAll("Tank try to suicide, but failed!");
		}
	}
	return Plugin_Continue;
}

#if !defined _l4dh_included
int CreateTank(int oldtank)
{
	int tank = 0;
	bool exsit[MAXPLAYERS + 1];
	for(int i = 1; i <= MaxClients; i++)
	{
		exsit[i] = false;
		if(IsValidTank(i) && IsPlayerAlive(i))
		{
			exsit[i] = true;
		}
	}

	int flags = GetCommandFlags("z_spawn");
	SetCommandFlags("z_spawn", flags & ~FCVAR_CHEAT);
	FakeClientCommand(oldtank, "z_spawn tank");
	SetCommandFlags("z_spawn", flags);

	for(int i = 1; i <= MaxClients; i++)
	{ 
		if(IsValidTank(i) && IsPlayerAlive(i))
		{
			if(!exsit[i])
			{
				tank = i;
				break;
			}
		}
	}
	return tank;
}
#endif

bool IsValidTank(int iTank)
{
	return iTank > 0 && iTank <= MaxClients && IsClientConnected(iTank) && IsClientInGame(iTank) && GetClientTeam(iTank) == 3 && GetEntProp(iTank, Prop_Send, "m_zombieClass") == zClassTank;
}
