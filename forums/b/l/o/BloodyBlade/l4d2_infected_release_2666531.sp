void CVarChange(ConVar convar, const char[] oldValue, const char[] newValue)
{
	if(convar == g_hConVar_PluginReleaseOn)
	{
		g_bPluginReleaseOn == g_hConVar_PluginReleaseOn.BoolValue;
	}
	else if(convar == g_hConVar_SmokerReleaseOn)
	{
		g_bSmokerEnabled = g_hConVar_SmokerReleaseOn.BoolValue;
	}
	else if(convar == g_hConVar_HunterReleaseOn)
	{
		g_bHunterEnabled = g_hConVar_HunterReleaseOn.BoolValue;
	}
	else if(convar == g_hConVar_SmokerAttackDelay)
	{
		g_fSmokerAttackDelay = g_hConVar_SmokerAttackDelay.FloatValue;
	}
	else if(convar == g_hConVar_HunterAttackDelay)
	{
		g_fHunterAttackDelay = g_hConVar_HunterAttackDelay.FloatValue;
	}

	if(g_bL4D2)
	{
		if(convar == g_hConVar_JockeyReleaseOn)
		{
			g_bJockeyEnabled = g_hConVar_JockeyReleaseOn.BoolValue;
		}
		else if(convar == g_hConVar_ChargerReleaseOn)
		{
			g_bChargerEnabled = g_hConVar_ChargerReleaseOn.BoolValue;
		}
		else if(convar == g_hConVar_JockeyAttackDelay)
		{
			g_fJockeyAttackDelay = g_hConVar_JockeyAttackDelay.FloatValue;
		}
		else if(convar == g_hConVar_ChargerAttackDelay)
		{
			g_fChargerAttackDelay = g_hConVar_ChargerAttackDelay.FloatValue;
		}
	}
}

