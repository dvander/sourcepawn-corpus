public Action OnPlayerRunCmd(int client, int &buttons, int &impulse, float vel[3], float angles[3], int &weapon)
{
	if (g_bPluginReleaseOn && client > 0 && IsClientInGame(client) && GetClientTeam(client) == 3 && IsPlayerAlive(client))
	{
		if (buttons & IN_ATTACK2 && !g_bButtonDelay[client])
		{
			if (GetClientTeam(client) == INFECTEDTEAM)
			{
				int h_vic = 0, zombieClass = GetEntProp(client, Prop_Send, "m_zombieClass");
				if (zombieClass == ZOMBIECLASS_SMOKER && g_bSmokerEnabled)
				{
					h_vic = GetEntPropEnt(client, Prop_Send, "m_tongueVictim");
					if (h_vic != 0 && IsValidEntity(h_vic))
					{
						#if defined _l4dh_included
						if(bL4DHLib)
						{
							L4D_Smoker_ReleaseVictim(h_vic, client);
						}
						#else
						CallOnReleaseTongueVictim(h_vic, client);
						#endif
						CreateTimer(g_fSmokerAttackDelay, ResetDelay, client);
						g_bButtonDelay[client] = true;
					}
				}
				else if (zombieClass == ZOMBIECLASS_HUNTER && g_bHunterEnabled)
				{
					h_vic = GetEntPropEnt(client, Prop_Send, "m_pounceVictim");
					if (h_vic != 0 && IsValidEntity(h_vic))
					{
						#if defined _l4dh_included
						if(bL4DHLib)
						{
							L4D_Hunter_ReleaseVictim(h_vic, client);
						}
						#else
						CallOnPounceEnd(h_vic, client);
						#endif
						CreateTimer(g_fHunterAttackDelay, ResetDelay, client);
						g_bButtonDelay[client] = true;
					}
				}
				
				if(g_bL4D2)
				{
					if (zombieClass == ZOMBIECLASS_JOCKEY && g_bJockeyEnabled)
					{
						h_vic = GetEntPropEnt(client, Prop_Send, "m_jockeyVictim");
						if (h_vic != 0 && IsValidEntity(h_vic))
						{
							#if defined _l4dh_included
							if(bL4DHLib)
							{
								L4D2_Jockey_EndRide(h_vic, client);
							}
							#else
							CallOnRideEnded(h_vic, client);
							#endif
							CreateTimer(g_fJockeyAttackDelay, ResetDelay, client);
							g_bButtonDelay[client] = true;
						}
					}
					else if (zombieClass == ZOMBIECLASS_CHARGER && g_bChargerEnabled)
					{
						h_vic = GetEntPropEnt(client, Prop_Send, "m_pummelVictim");
						if (h_vic != 0 && IsValidEntity(h_vic))
						{
							#if defined _l4dh_included
							if(bL4DHLib)
							{
								L4D2_Charger_EndPummel(h_vic, client);
							}
							#else
							CallOnPummelEnded(h_vic, client);
							if (g_hConVar_ChargerChargeInterval != null) CallResetAbility(client, g_hConVar_ChargerChargeInterval.FloatValue);
							#endif
							CreateTimer(g_fChargerAttackDelay, ResetDelay, client);
							g_bButtonDelay[client] = true;
						}
					}
				}
			}
		}
		
		// If delayed, don't let them click
		if (buttons & IN_ATTACK && g_bButtonDelay[client])
		{
			buttons &= ~IN_ATTACK;
		}
		
		// If delayed, don't let them click
		if (buttons & IN_ATTACK2 && g_bButtonDelay[client])
		{
			buttons &= ~IN_ATTACK2;
		}
	}
	return Plugin_Continue;
}

Action ResetDelay(Handle timer, any client)
{
	g_bButtonDelay[client] = false;
	return Plugin_Stop;
}
